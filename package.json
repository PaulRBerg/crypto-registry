{
  "name": "@prb/crypto-registry",
  "description": "Typed, isomorphic registry of EVM chains, ERC-20 tokens, and HD derivation metadata.",
  "homepage": "https://github.com/PaulRBerg/crypto-registry#readme",
  "license": "MIT",
  "main": "./dist/index.js",
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "1.0.0",
  "files": [
    "dist/**",
    "data/**"
  ],
  "keywords": [
    "erc20",
    "ethereum",
    "evm",
    "bip32",
    "derivation-path",
    "hd-wallet",
    "slip44",
    "stablecoin",
    "token-list",
    "tokens",
    "wrapped"
  ],
  "author": {
    "name": "Paul Razvan Berg",
    "url": "https://github.com/PaulRBerg"
  },
  "bugs": {
    "url": "https://github.com/PaulRBerg/crypto-registry/issues"
  },
  "dependencies": {
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@prb/devkit": "^1.0.0",
    "@types/node": "^25.0.3",
    "@typescript/native-preview": "^7.0.0-dev.20260624.1",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "ultracite": "^7.8.3",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "viem": "^2.54.6"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./derivations": {
      "types": "./dist/derivations/index.d.ts",
      "import": "./dist/derivations/index.js"
    },
    "./tokens.json": "./data/tokens.json",
    "./chains.json": "./data/chains.json",
    "./internal/*": null,
    "./package.json": "./package.json"
  },
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PaulRBerg/crypto-registry.git"
  }
}
